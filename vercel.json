{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { 
      "src": "/(.*)", 
      "dest": "api/index.py",
      "methods": ["GET", "POST", "OPTIONS", "PUT", "PATCH", "DELETE"],
      "headers": { "Access-Control-Allow-Origin": "*" }
    }
  ]
}
